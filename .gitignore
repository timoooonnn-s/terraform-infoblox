# Credentials (only the .example template is committed)
credentials.auto.tfvars

# Terraform state and crash logs
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Provider plugins / saved plans
.terraform/
*.tfplan
plan.cache
plan.json

# NOTE: .terraform.lock.hcl is intentionally NOT ignored.
# Commit it so pipeline runs use identical, reproducible provider versions.

# Local backend selection + overrides (used for hand-runs; never committed)
backend-config.local.tfbackend
*_override.tf
*_override.tf.json
override.tf
override.tf.json

#ignore claude code folder
.claude